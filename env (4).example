import { useEffect, useState } from "react";
import { useSearchParams } from "react-router-dom";
import { Filter, X, ChevronDown } from "lucide-react";
import ProductCard from "../components/ProductCard.jsx";
import { getProducts } from "../utils/api.js";

const categories = ["all", "ethnic", "western", "casual", "formal", "accessories"];
const sizes = ["XS", "S", "M", "L", "XL", "XXL"];
const sortOptions = [
  { label: "Newest", value: "newest" },
  { label: "Price: Low to High", value: "price_asc" },
  { label: "Price: High to Low", value: "price_desc" },
];

export default function Shop() {
  const [searchParams, setSearchParams] = useSearchParams();
  const [products, setProducts] = useState([]);
  const [loading, setLoading] = useState(true);
  const [filtersOpen, setFiltersOpen] = useState(false);

  const [filters, setFilters] = useState({
    category: searchParams.get("category") || "all",
    sort: searchParams.get("sort") || "newest",
    size: "",
    minPrice: "",
    maxPrice: "",
  });

  useEffect(() => {
    setLoading(true);
    const params = {};
    if (filters.category && filters.category !== "all") params.category = filters.category;
    if (filters.sort) params.sort = filters.sort;
    if (filters.size) params.size = filters.size;
    if (filters.minPrice) params.minPrice = filters.minPrice;
    if (filters.maxPrice) params.maxPrice = filters.maxPrice;

    getProducts(params)
      .then((res) => setProducts(res.data.products))
      .catch(() => setProducts([]))
      .finally(() => setLoading(false));
  }, [filters]);

  const setFilter = (key, value) => {
    setFilters((prev) => ({ ...prev, [key]: value }));
    setSearchParams((prev) => {
      if (value && value !== "all") prev.set(key, value);
      else prev.delete(key);
      return prev;
    });
  };

  const clearFilters = () => {
    setFilters({ category: "all", sort: "newest", size: "", minPrice: "", maxPrice: "" });
    setSearchParams({});
  };

  const activeFiltersCount = [filters.category !== "all", filters.size, filters.minPrice, filters.maxPrice].filter(Boolean).length;

  return (
    <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 page-enter">
      {/* Header */}
      <div className="flex items-end justify-between mb-10">
        <div>
          <span className="font-body text-xs tracking-[0.4em] uppercase text-brand-400">Browse</span>
          <h1 className="section-title text-4xl mt-1">All Products</h1>
        </div>
        <span className="font-body text-xs text-dark-300">{products.length} items</span>
      </div>

      <div className="flex gap-8">
        {/* Sidebar filters (desktop) */}
        <aside className="hidden md:block w-56 flex-shrink-0">
          <div className="sticky top-24 space-y-8">
            {/* Category */}
            <div>
              <h3 className="font-body text-xs tracking-widest uppercase text-brand-400 mb-4">Category</h3>
              <div className="space-y-2">
                {categories.map((cat) => (
                  <button key={cat} onClick={() => setFilter("category", cat)}
                    className={`block w-full text-left font-body text-sm py-1.5 transition-colors capitalize ${filters.category === cat ? "text-brand-400" : "text-dark-300 hover:text-dark-100"}`}>
                    {cat === "all" ? "All" : cat}
                  </button>
                ))}
              </div>
            </div>

            {/* Size */}
            <div>
              <h3 className="font-body text-xs tracking-widest uppercase text-brand-400 mb-4">Size</h3>
              <div className="flex flex-wrap gap-2">
                {sizes.map((s) => (
                  <button key={s} onClick={() => setFilter("size", filters.size === s ? "" : s)}
                    className={`w-10 h-10 font-body text-xs border transition-colors ${filters.size === s ? "border-brand-500 bg-brand-500/10 text-brand-400" : "border-dark-600 text-dark-300 hover:border-dark-400"}`}>
                    {s}
                  </button>
                ))}
              </div>
            </div>

            {/* Price range */}
            <div>
              <h3 className="font-body text-xs tracking-widest uppercase text-brand-400 mb-4">Price (₹)</h3>
              <div className="flex gap-2">
                <input type="number" placeholder="Min" value={filters.minPrice}
                  onChange={(e) => setFilter("minPrice", e.target.value)}
                  className="input-field text-xs py-2 w-full" />
                <input type="number" placeholder="Max" value={filters.maxPrice}
                  onChange={(e) => setFilter("maxPrice", e.target.value)}
                  className="input-field text-xs py-2 w-full" />
              </div>
            </div>

            {activeFiltersCount > 0 && (
              <button onClick={clearFilters} className="text-brand-400 font-body text-xs tracking-wider uppercase flex items-center gap-1 hover:text-brand-300">
                <X size={12} /> Clear Filters
              </button>
            )}
          </div>
        </aside>

        {/* Products grid */}
        <div className="flex-1">
          {/* Sort + mobile filter bar */}
          <div className="flex items-center justify-between mb-6 gap-4">
            <button onClick={() => setFiltersOpen(!filtersOpen)}
              className="md:hidden flex items-center gap-2 font-body text-xs tracking-widest uppercase text-dark-200 border border-dark-600 px-4 py-2">
              <Filter size={14} /> Filters {activeFiltersCount > 0 && `(${activeFiltersCount})`}
            </button>
            <div className="flex items-center gap-2 ml-auto">
              <span className="font-body text-xs text-dark-400 hidden sm:inline">Sort:</span>
              <select value={filters.sort} onChange={(e) => setFilter("sort", e.target.value)}
                className="bg-dark-800 border border-dark-600 text-dark-200 font-body text-xs px-3 py-2 focus:outline-none focus:border-brand-500">
                {sortOptions.map((o) => <option key={o.value} value={o.value}>{o.label}</option>)}
              </select>
            </div>
          </div>

          {loading ? (
            <div className="grid grid-cols-2 lg:grid-cols-3 gap-5">
              {[...Array(6)].map((_, i) => <div key={i} className="aspect-[3/4] shimmer" />)}
            </div>
          ) : products.length > 0 ? (
            <div className="grid grid-cols-2 lg:grid-cols-3 gap-5">
              {products.map((p) => <ProductCard key={p.id} product={p} />)}
            </div>
          ) : (
            <div className="text-center py-32 text-dark-400 font-body">
              <p className="text-5xl mb-4">🛍️</p>
              <p className="text-lg font-display">No products found</p>
              <p className="text-sm mt-2">Try adjusting your filters</p>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}
