import { useEffect, useState } from "react";
import { Instagram, Facebook, Twitter, Youtube, MessageCircle, Globe, Loader, ExternalLink } from "lucide-react";
import { getSettings, updateSocialSettings } from "../../utils/api.js";
import toast from "react-hot-toast";

const platforms = [
  { key: "instagram", label: "Instagram", Icon: Instagram, placeholder: "https://instagram.com/yourstore", color: "text-pink-400" },
  { key: "facebook", label: "Facebook", Icon: Facebook, placeholder: "https://facebook.com/yourpage", color: "text-blue-400" },
  { key: "twitter", label: "Twitter / X", Icon: Twitter, placeholder: "https://twitter.com/yourhandle", color: "text-sky-400" },
  { key: "youtube", label: "YouTube", Icon: Youtube, placeholder: "https://youtube.com/@yourchannel", color: "text-red-400" },
  { key: "whatsapp", label: "WhatsApp", Icon: MessageCircle, placeholder: "91XXXXXXXXXX (number with country code)", color: "text-green-400" },
  { key: "website", label: "Website", Icon: Globe, placeholder: "https://yourstore.com", color: "text-brand-400" },
];

export default function AdminSocial() {
  const [form, setForm] = useState({});
  const [loading, setLoading] = useState(true);
  const [saving, setSaving] = useState(false);

  useEffect(() => {
    getSettings().then((res) => setForm(res.data.social || {})).finally(() => setLoading(false));
  }, []);

  const handleSave = async () => {
    setSaving(true);
    try {
      await updateSocialSettings(form);
      toast.success("Social links saved!");
    } catch { toast.error("Save failed"); }
    finally { setSaving(false); }
  };

  if (loading) return <div className="p-8"><div className="h-96 shimmer" /></div>;

  return (
    <div className="p-8 max-w-2xl">
      <h1 className="font-display text-4xl font-light text-dark-50 mb-2">Social Links</h1>
      <p className="font-body text-sm text-dark-400 mb-8">These links appear in your store's footer and help customers find you online.</p>

      <div className="card p-6 space-y-5">
        {platforms.map(({ key, label, Icon, placeholder, color }) => (
          <div key={key}>
            <label className="flex items-center gap-2 font-body text-xs tracking-widest uppercase text-dark-400 mb-2">
              <Icon size={13} className={color} /> {label}
            </label>
            <div className="flex gap-2">
              <input value={form[key] || ""} onChange={(e) => setForm({ ...form, [key]: e.target.value })}
                placeholder={placeholder} className="input-field flex-1" />
              {form[key] && (
                <a href={key === "whatsapp" ? `https://wa.me/${form[key].replace(/\D/g, "")}` : form[key].startsWith("http") ? form[key] : `https://${form[key]}`}
                  target="_blank" rel="noopener noreferrer"
                  className="flex items-center px-3 border border-dark-600 text-dark-400 hover:text-brand-400 hover:border-brand-500 transition-colors">
                  <ExternalLink size={14} />
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <button onClick={handleSave} disabled={saving} className="btn-primary mt-6 flex items-center gap-2 disabled:opacity-50">
        {saving && <Loader size={14} className="animate-spin" />} Save Social Links
      </button>

      <div className="mt-8 card p-4">
        <p className="font-body text-xs text-dark-400">
          <span className="text-brand-400 font-500">Preview:</span> These icons will appear in the footer of your store. Empty fields won't be shown.
        </p>
        <div className="flex gap-3 mt-3">
          {platforms.filter(({ key }) => form[key]).map(({ key, Icon, color }) => (
            <Icon key={key} size={18} className={color} />
          ))}
          {!platforms.some(({ key }) => form[key]) && <p className="text-dark-500 font-body text-xs">No links added yet</p>}
        </div>
      </div>
    </div>
  );
}
